# Copy to .env and fill in values
# Never commit .env to git

DATABASE_URL=sqlite:///./geargap_dev.db

BLIZZARD_CLIENT_ID=your_client_id
BLIZZARD_CLIENT_SECRET=your_client_secret

# Raidbots static data hash — rotate on each game client build
# How to get: https://www.raidbots.com/developers → Network tab → static/data/{hash}/...
RAIDBOTS_HASH=your_raidbots_hash

# Current WoW patch version — must match a row in patch_versions table
# Example: 11.1.5
CURRENT_PATCH_VERSION=11.1.5

# Phase 2
ANTHROPIC_API_KEY=
